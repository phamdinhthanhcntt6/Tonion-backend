generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Lưu ý: Với Prisma 7, URL được cấu hình trong prisma.config.ts
}

// ----------------------------------------------------
// 1. NGƯỜI DÙNG (PROFILES)
// ----------------------------------------------------
model Profile {
  id            String    @id @default(uuid())
  email         String    @unique
  fullName      String
  avatarUrl     String?
  coverImageUrl String?
  role          Role      @default(USER)
  bio           String?
  socialLinks   Json?

  // Quan hệ
  songs         SongVideo[]
  interactions  Interaction[]
  posts         Post[]
  comments      Comment[]
  followers     Follow[]  @relation("Following")
  following     Follow[]  @relation("Follower")
  notifications Notification[]
  playlists     Playlist[]
  products      MarketplaceItem[]
  orders        Order[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

enum Role {
  USER
  ARTIST
  ADMIN
}

// ----------------------------------------------------
// 2. NỘI DUNG MEDIA (SONG/VIDEO)
// ----------------------------------------------------
model SongVideo {
  id              String    @id @default(uuid())
  title           String
  description     String?
  mediaUrl        String
  thumbnailUrl    String?
  type            MediaType
  genre           String?
  durationSeconds Int
  viewCount       Int       @default(0)
  likeCount       Int       @default(0)
  isPublished     Boolean   @default(false)

  artistId        String
  artist          Profile   @relation(fields: [artistId], references: [id])

  // BỔ SUNG QUAN HỆ ĐỐI ỨNG
  interactions    Interaction[]
  comments        Comment[]
  playlistItems   PlaylistItem[]

  createdAt       DateTime  @default(now())
}

enum MediaType {
  MUSIC
  VIDEO
}

// ----------------------------------------------------
// 3. TƯƠNG TÁC (LIKES / VOTES)
// ----------------------------------------------------
model Interaction {
  id         String     @id @default(uuid())
  userId     String
  targetId   String
  targetType TargetType
  type       ActionType

  user       Profile    @relation(fields: [userId], references: [id])
  
  // SỬA LỖI TẠI ĐÂY: Bổ sung quan hệ tới các bảng đích
  song       SongVideo? @relation(fields: [targetId], references: [id], map: "interaction_song_fk")
  post       Post?      @relation(fields: [targetId], references: [id], map: "interaction_post_fk")

  createdAt  DateTime   @default(now())

  @@unique([userId, targetId, type])
}

enum TargetType {
  SONG
  VIDEO
  POST
}

enum ActionType {
  LIKE
  VOTE
  FAVORITE
}

// ----------------------------------------------------
// 4. MẠNG XÃ HỘI (POSTS & COMMENTS)
// ----------------------------------------------------
model Post {
  id              String    @id @default(uuid())
  content         String
  attachedMediaId String?
  imageUrls       Json?
  likeCount       Int       @default(0)
  commentCount    Int       @default(0)

  authorId        String
  author          Profile   @relation(fields: [authorId], references: [id])

  // BỔ SUNG QUAN HỆ ĐỐI ỨNG
  interactions    Interaction[]
  comments        Comment[]

  createdAt       DateTime  @default(now())
}

model Comment {
  id         String     @id @default(uuid())
  content    String
  targetId   String
  targetType TargetType
  parentId   String?

  userId     String
  user       Profile    @relation(fields: [userId], references: [id])
  
  // BỔ SUNG QUAN HỆ ĐỐI ỨNG ĐẾN NGUỒN
  song       SongVideo? @relation(fields: [targetId], references: [id], map: "comment_song_fk")
  post       Post?      @relation(fields: [targetId], references: [id], map: "comment_post_fk")

  parent     Comment?   @relation("CommentReplies", fields: [parentId], references: [id])
  replies    Comment[]  @relation("CommentReplies")

  createdAt  DateTime   @default(now())
}

// ----------------------------------------------------
// 5. THEO DÕI (FOLLOWS)
// ----------------------------------------------------
model Follow {
  id          String   @id @default(uuid())
  followerId  String
  followingId String

  follower    Profile  @relation("Follower", fields: [followerId], references: [id])
  following   Profile  @relation("Following", fields: [followingId], references: [id])

  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
}

// ----------------------------------------------------
// 6. THÔNG BÁO (NOTIFICATIONS)
// ----------------------------------------------------
model Notification {
  id            String      @id @default(uuid())
  type          NotifType
  referenceId   String?
  referenceType TargetType?
  isRead        Boolean     @default(false)

  userId        String
  user          Profile     @relation(fields: [userId], references: [id])
  actorId       String

  createdAt     DateTime    @default(now())
}

enum NotifType {
  LIKE
  COMMENT
  FOLLOW
  NEW_SONG
}

// ----------------------------------------------------
// 7. PLAYLIST & MARKETPLACE
// ----------------------------------------------------
model Playlist {
  id        String         @id @default(uuid())
  title     String
  coverUrl  String?
  isPublic  Boolean        @default(true)
  ownerId   String
  owner     Profile        @relation(fields: [ownerId], references: [id])
  items     PlaylistItem[]
  createdAt DateTime       @default(now())
}

model PlaylistItem {
  id         String    @id @default(uuid())
  position   Int
  playlistId String
  songId     String

  playlist   Playlist  @relation(fields: [playlistId], references: [id])
  song       SongVideo @relation(fields: [songId], references: [id])
  addedAt    DateTime  @default(now())
}

model MarketplaceItem {
  id           String    @id @default(uuid())
  title        String
  priceVnd     Int
  thumbnailUrl String?
  isActive     Boolean   @default(true)
  sellerId     String
  seller       Profile   @relation(fields: [sellerId], references: [id])
  orders       Order[]
  createdAt    DateTime  @default(now())
}

model Order {
  id         String          @id @default(uuid())
  amountVnd  Int
  status     OrderStatus     @default(PENDING)
  paymentRef String?

  buyerId    String
  buyer      Profile         @relation(fields: [buyerId], references: [id])
  itemId     String
  item       MarketplaceItem @relation(fields: [itemId], references: [id])
  createdAt  DateTime        @default(now())
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
}